{
  "name": "kengo",
  "version": "0.0.2",
  "engines": {
    "node": "22.16.0"
  },
  "scripts": {
    "ports": "node scripts/dev-ports.mjs",
    "ng": "ng",
    "start": "node scripts/start-menu.mjs",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy",
    "build": "nx build app",
    "build:all": "nx run-many -t build",
    "build:native": "nx build app --configuration native",
    "watch": "nx build app --watch --configuration development",
    "cap:assets": "cd apps/app && npx @capacitor/assets generate --iconBackgroundColor '#e75c3e' --iconBackgroundColorDark '#e75c3e' --splashBackgroundColor '#ffffff' --splashBackgroundColorDark '#ffffff'",
    "cap:sync": "npm run build:native && cd apps/app && npx cap sync",
    "cap:sync:ios": "npm run build:native && cd apps/app && npx cap sync ios",
    "cap:sync:android": "npm run build:native && cd apps/app && npx cap sync android",
    "cap:open:ios": "cd apps/app && npx cap open ios",
    "cap:open:android": "cd apps/app && npx cap open android",
    "cap:run:ios": "cd apps/app && npx cap run ios",
    "cap:run:android": "cd apps/app && npx cap run android",
    "test": "nx test app",
    "lint": "nx lint app",
    "start:landingpage": "nx serve landingpage",
    "build:landingpage": "nx build landingpage",
    "lint:landingpage": "nx lint landingpage",
    "graph": "nx graph",
    "e2e": "playwright test",
    "e2e:screenshots": "playwright test e2e/screenshots",
    "e2e:ui": "playwright test --ui",
    "e2e:setup": "playwright test --project=setup",
    "railway:build:frontend": "nx build app --configuration production",
    "railway:start:frontend": "node apps/app/server.js",
    "railway:build:landingpage": "nx build landingpage --configuration production",
    "railway:start:landingpage": "node apps/landingpage/server.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.1",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/service-worker": "^20.0.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
