{
  "name": "landingpage",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "web",
  "sourceRoot": "apps/landingpage/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/landingpage",
        "browser": "apps/landingpage/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/landingpage/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/landingpage/public"
          },
          {
            "glob": "favicon.ico",
            "input": "apps/landingpage/src"
          }
        ],
        "styles": ["apps/landingpage/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "300kb",
              "maximumError": "500kb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "15kb",
              "maximumError": "30kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4202
      },
      "configurations": {
        "production": {
          "buildTarget": "landingpage:build:production"
        },
        "development": {
          "buildTarget": "landingpage:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "landingpage:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/landingpage/jest.config.ts",
        "tsConfig": "apps/landingpage/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "landingpage:build",
        "port": 4202,
        "staticFilePath": "dist/apps/landingpage/browser",
        "spa": true
      }
    }
  }
}
