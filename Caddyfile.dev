# Kengo - Desarrollo local
# Uso: caddy run --config Caddyfile.dev
#
# https://kengo.localhost      → App Angular  (4200)
# https://kengo-api.localhost  → Backend API  (4201)
# https://kengo-web.localhost  → Landing Page (4202)

kengo.localhost {
	reverse_proxy localhost:4200
}

kengo-api.localhost {
	reverse_proxy localhost:4201
}

kengo-web.localhost {
	reverse_proxy localhost:4202
}
