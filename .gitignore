# See http://help.github.com/ignore-files/ for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
# node_modules de workspaces npm (p. ej. convex/node_modules/)
**/node_modules
npm-debug.log
yarn-error.log

# Nx
.nx/cache
.nx/workspace-data
.nx/installation
nxcloud.env

# Claude Code
.claude/

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Capacitor — assets web sincronizados desde dist/ a las carpetas nativas.
# Se regeneran con `npx cap sync` y no deben versionarse.
apps/app/ios/App/App/public/
apps/app/android/app/src/main/assets/public/
# Capacitor — derived JSON config (regenerada cada sync)
apps/app/ios/App/App/capacitor.config.json
apps/app/android/app/src/main/assets/capacitor.config.json
apps/app/android/app/src/main/assets/capacitor.plugins.json

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Playwright
/e2e/.auth/
/playwright-report/
/test-results/
/screenshots/
.env.e2e
.env.local

# Playwright MCP runtime artifacts (logs, screenshots, snapshots)
.playwright-mcp/

# Figma handoff (referencia local del rediseño cream wellness, no versionado)
/diseño/

.angular
